# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Supabase metadata
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Senha do banco Postgres (Settings → Database) — para rodar: npm run migrate:supabase --prefix apps/api
# Ou use DATABASE_URL com a URI completa (modo Session).
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres:...@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# App
NODE_ENV=development
WEB_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
MAX_PDF_UPLOAD_SIZE_BYTES=15728640
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_PAYSLIPS=payslips
STORAGE_BUCKET_CANDIDATE_RESUMES=candidate-resumes
STORAGE_BUCKET_CANDIDATE_AVATARS=candidate-avatars
RESEND_API_KEY=
EMAIL_FROM=

# E-mails com acesso ao painel /superadmin (separados por vírgula). Padrão na API: tools@pontoumdigital.com.br
PLATFORM_SUPERADMIN_EMAILS=tools@pontoumdigital.com.br

# IA (filas em processo Node local; na Vercel use 0 ou configure Cron à parte)
# AI_PAYSLIP_QUEUE_MS=15000
# AI_RESUME_QUEUE_MS=25000

# --- Deploy na Vercel (Root Directory: apps/web) ---
# O Next serve o frontend; a API Express fica em /api (mesmo domínio). Não é obrigatório NEXT_PUBLIC_API_BASE_URL.
# Inclua na Vercel as mesmas variáveis da API (SUPABASE_SERVICE_ROLE_KEY, WEB_ALLOWED_ORIGINS com https://seu-projeto.vercel.app, etc.).
# Em serverless não há timers contínuos: defina AI_PAYSLIP_QUEUE_MS=0 e AI_RESUME_QUEUE_MS=0 ou use Vercel Cron mais tarde.
# Limite de corpo das funções serverless (plano Hobby) ~4.5 MB; PDFs muito grandes podem exigir upload direto ao Supabase Storage.
