{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "apps/web/pages/api/[[...path]].ts": {
      "maxDuration": 60
    },
    "apps/web/app/api/**": {
      "maxDuration": 60
    }
  }
}
